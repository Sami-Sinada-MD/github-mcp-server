{
  "openapi": "3.0.3",
  "info": {
    "title": "GitHub MCP Server HTTP API",
    "description": "OpenAPI specification for the GitHub MCP Server streamable HTTP transport and OAuth protected resource metadata endpoints.\n\nThe server exposes the Model Context Protocol (MCP) over streamable HTTP. Clients send JSON-RPC 2.0 messages via POST, may open SSE streams via GET, and terminate sessions via DELETE.\n\nStart the server with `github-mcp-server http` (default port 8082).",
    "version": "version"
  },
  "servers": [
    {
      "url": "http://localhost:8082",
      "description": "Local development server (default port from `github-mcp-server http --port`)"
    }
  ],
  "tags": [
    {
      "name": "MCP",
      "description": "Model Context Protocol streamable HTTP transport endpoints"
    },
    {
      "name": "OAuth",
      "description": "OAuth 2.0 Protected Resource Metadata (RFC 9728) discovery endpoints"
    }
  ],
  "paths": {
    "/": {
      "post": {
        "operationId": "postMcpJsonRpc",
        "summary": "Send MCP JSON-RPC request",
        "description": "Primary MCP transport endpoint. Accepts JSON-RPC 2.0 requests such as `initialize`, `tools/list`, `tools/call`, `resources/read`, and `prompts/get`.",
        "tags": ["MCP"],
        "parameters": [
          { "$ref": "#/components/parameters/McpSessionId" },
          { "$ref": "#/components/parameters/McpProtocolVersion" },
          { "$ref": "#/components/parameters/McpReadonly" },
          { "$ref": "#/components/parameters/McpToolsets" },
          { "$ref": "#/components/parameters/McpTools" },
          { "$ref": "#/components/parameters/McpExcludeTools" },
          { "$ref": "#/components/parameters/McpFeatures" },
          { "$ref": "#/components/parameters/McpLockdown" },
          { "$ref": "#/components/parameters/McpInsiders" }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/McpJsonRpcRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "JSON-RPC response or accepted request for streaming",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/McpJsonRpcResponse" }
              },
              "text/event-stream": {
                "schema": { "type": "string", "description": "Server-sent events for streaming MCP responses" }
              }
            }
          },
          "400": { "description": "Bad request — malformed Authorization header or unknown tools" },
          "401": { "description": "Unauthorized — missing Authorization header", "headers": { "WWW-Authenticate": { "schema": { "type": "string" } } } },
          "403": { "description": "Forbidden — insufficient OAuth scopes when `--scope-challenge` is enabled", "headers": { "WWW-Authenticate": { "schema": { "type": "string" } } } },
          "415": { "description": "Unsupported Media Type — Content-Type must be application/json" },
          "500": { "description": "Internal server error" }
        },
        "security": [{ "BearerAuth": [] }]
      },
      "get": {
        "operationId": "getMcpEventStream",
        "summary": "Open MCP SSE stream",
        "description": "Streamable HTTP GET endpoint for server-sent event responses.",
        "tags": ["MCP"],
        "parameters": [
          { "$ref": "#/components/parameters/McpSessionId" },
          { "$ref": "#/components/parameters/LastEventId" },
          { "$ref": "#/components/parameters/McpProtocolVersion" }
        ],
        "responses": {
          "200": {
            "description": "Event stream",
            "content": {
              "text/event-stream": {
                "schema": { "type": "string" }
              }
            }
          },
          "401": { "description": "Unauthorized — missing Authorization header", "headers": { "WWW-Authenticate": { "schema": { "type": "string" } } } },
          "403": { "description": "Forbidden — insufficient OAuth scopes when `--scope-challenge` is enabled" },
          "500": { "description": "Internal server error" }
        },
        "security": [{ "BearerAuth": [] }]
      },
      "delete": {
        "operationId": "deleteMcpSession",
        "summary": "Terminate MCP session",
        "description": "Streamable HTTP DELETE endpoint used to terminate an MCP session.",
        "tags": ["MCP"],
        "parameters": [
          { "$ref": "#/components/parameters/McpSessionId" },
          { "$ref": "#/components/parameters/McpProtocolVersion" }
        ],
        "responses": {
          "200": { "description": "Session terminated" },
          "401": { "description": "Unauthorized — missing Authorization header", "headers": { "WWW-Authenticate": { "schema": { "type": "string" } } } },
          "500": { "description": "Internal server error" }
        },
        "security": [{ "BearerAuth": [] }]
      },
      "options": {
        "operationId": "optionsMcpCors",
        "summary": "CORS preflight for MCP endpoints",
        "tags": ["MCP"],
        "responses": {
          "200": { "description": "CORS preflight succeeded" }
        },
        "security": []
      }
    },
    "/readonly": {
      "post": {
        "operationId": "postMcpJsonRpcReadonly",
        "summary": "Send MCP JSON-RPC request (read-only mode)",
        "description": "Same as POST `/` but the server registers only read-only MCP tools.",
        "tags": ["MCP"],
        "parameters": [
          { "$ref": "#/components/parameters/McpSessionId" },
          { "$ref": "#/components/parameters/McpProtocolVersion" }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/McpJsonRpcRequest" }
            }
          }
        },
        "responses": {
          "200": { "description": "JSON-RPC response", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/McpJsonRpcResponse" } } } },
          "400": { "description": "Bad request" },
          "401": { "description": "Unauthorized", "headers": { "WWW-Authenticate": { "schema": { "type": "string" } } } },
          "403": { "description": "Forbidden — insufficient OAuth scopes" },
          "500": { "description": "Internal server error" }
        },
        "security": [{ "BearerAuth": [] }]
      },
      "options": {
        "operationId": "optionsMcpReadonlyCors",
        "summary": "CORS preflight for read-only MCP endpoint",
        "tags": ["MCP"],
        "responses": { "200": { "description": "CORS preflight succeeded" } },
        "security": []
      }
    },
    "/insiders": {
