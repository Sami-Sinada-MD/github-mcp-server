  "components": {
    "securitySchemes": {
      "BearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "description": "GitHub OAuth access token, personal access token (PAT), or GitHub App token supplied in the Authorization header."
      }
    },
    "parameters": {
      "McpSessionId": {
        "name": "Mcp-Session-Id",
        "in": "header",
        "required": false,
        "schema": { "type": "string" },
        "description": "MCP session identifier for streamable HTTP transport."
      },
      "McpProtocolVersion": {
        "name": "Mcp-Protocol-Version",
        "in": "header",
        "required": false,
        "schema": { "type": "string" },
        "description": "Requested MCP protocol version."
      },
      "LastEventId": {
        "name": "Last-Event-ID",
        "in": "header",
        "required": false,
        "schema": { "type": "string" },
        "description": "Resume point for SSE streams."
      },
      "McpReadonly": {
        "name": "X-MCP-Readonly",
        "in": "header",
        "required": false,
        "schema": { "type": "string" },
        "description": "When true, restricts the MCP inventory to read-only tools."
      },
      "McpToolsets": {
        "name": "X-MCP-Toolsets",
        "in": "header",
        "required": false,
        "schema": { "type": "string" },
        "description": "Comma-separated list of MCP toolsets to enable for the request."
      },
      "McpTools": {
        "name": "X-MCP-Tools",
        "in": "header",
        "required": false,
        "schema": { "type": "string" },
        "description": "Comma-separated list of specific MCP tools to enable for the request."
      },
      "McpExcludeTools": {
        "name": "X-MCP-Exclude-Tools",
        "in": "header",
        "required": false,
        "schema": { "type": "string" },
        "description": "Comma-separated list of MCP tools to exclude from the request."
      },
      "McpFeatures": {
        "name": "X-MCP-Features",
        "in": "header",
        "required": false,
        "schema": { "type": "string" },
        "description": "Comma-separated list of feature flags to enable for the request."
      },
      "McpLockdown": {
        "name": "X-MCP-Lockdown",
        "in": "header",
        "required": false,
        "schema": { "type": "string" },
        "description": "When true, enables lockdown mode for repository access checks."
      },
      "McpInsiders": {
        "name": "X-MCP-Insiders",
        "in": "header",
        "required": false,
        "schema": { "type": "string" },
        "description": "When true, enables insiders mode for early-access MCP tools."
      }
    },
    "schemas": {
      "McpJsonRpcRequest": {
        "type": "object",
        "required": ["jsonrpc", "method"],
        "properties": {
          "jsonrpc": {
            "type": "string",
            "enum": ["2.0"]
          },
          "id": {
            "oneOf": [
              { "type": "string" },
              { "type": "integer", "format": "int64" },
              { "type": "null", "nullable": true }
            ]
          },
          "method": {
            "type": "string",
            "description": "MCP JSON-RPC method name such as initialize, tools/list, tools/call, resources/read, or prompts/get."
          },
          "params": {
            "type": "object",
            "additionalProperties": true,
            "properties": {
              "protocolVersion": { "type": "string" },
              "capabilities": { "type": "object", "additionalProperties": true },
              "clientInfo": { "$ref": "#/components/schemas/McpClientInfo" },
              "name": { "type": "string", "description": "Tool or prompt name for tools/call and prompts/get." },
              "arguments": { "type": "object", "additionalProperties": true },
              "uri": { "type": "string", "description": "Resource URI for resources/read." }
            }
          }
        }
      },
      "McpJsonRpcResponse": {
        "type": "object",
        "required": ["jsonrpc"],
        "properties": {
          "jsonrpc": {
            "type": "string",
            "enum": ["2.0"]
          },
          "id": {
            "oneOf": [
              { "type": "string" },
              { "type": "integer", "format": "int64" },
              { "type": "null", "nullable": true }
            ]
          },
          "result": {
            "type": "object",
            "additionalProperties": true,
            "description": "Successful JSON-RPC result payload. Shape depends on the MCP method."
          },
          "error": {
            "$ref": "#/components/schemas/McpJsonRpcError"
          }
        }
      },
      "McpJsonRpcError": {
        "type": "object",
        "required": ["code", "message"],
        "properties": {
          "code": { "type": "integer", "format": "int32" },
          "message": { "type": "string" },
          "data": { "type": "object", "additionalProperties": true, "nullable": true }
        }
      },
      "McpClientInfo": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "version": { "type": "string" }
        }
      },
      "OAuthProtectedResourceMetadata": {
        "type": "object",
        "required": [
          "resource",
          "authorization_servers",
          "bearer_methods_supported",
          "scopes_supported"
        ],
        "properties": {
          "resource": {
            "type": "string",
            "format": "uri",
            "description": "Protected MCP resource URL."
          },
          "resource_name": {
            "type": "string",
            "description": "Human-readable resource name.",
            "example": "GitHub MCP Server"
          },
          "authorization_servers": {
            "type": "array",
            "items": { "type": "string", "format": "uri" },
            "description": "OAuth authorization server URLs."
          },
          "bearer_methods_supported": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Supported bearer token transport methods.",
            "example": ["header"]
          },
          "scopes_supported": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": [
                "repo",
                "read:org",
                "read:user",
                "user:email",
                "read:packages",
                "write:packages",
                "read:project",
                "project",
                "gist",
                "notifications",
                "workflow",
                "codespace"
              ]
            }
          }
        }
      }
    }
  },
  "security": [{ "BearerAuth": [] }]
}
